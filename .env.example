# ÖNEMLİ: .env Git’e gitmez. Railway’de Variables’a da ekleyin.

PORT=3000
JWT_SECRET=uzun-guclu-gizli-anahtar
CORS_ORIGIN=http://localhost:3000/

# ——— Veritabanı (aynı DB: lokal + canlı) ———
# Railway Postgres → Connect → Public Network → “Database URL”
# Sadece bunu kullanabilirsiniz (Prisma otomatik DATABASE_URL’e çevirir):
# Database (Local Development - SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Database (Production - Railway PostgreSQL)
# DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"
# Örnek:
# DATABASE_URL="postgresql://postgres:WyzVGFTAvzETjfkWwpSQxlVTSUTOvHEE@gondola.proxy.rlwy.net:25356/railway"
DATABASE_PUBLIC_URL="postgresql://postgres:WyzVGFTAvzETjfkWwpSQxlVTSUTOvHEE@gondola.proxy.rlwy.net:25356/railway"

# İsteğe bağlı: Railway içinden deploy’da iç ağ (postgres.railway.internal) daha hızlıdır.
# Tanımlıysa önce bu okunur; yoksa DATABASE_PUBLIC_URL kullanılır.
# DATABASE_URL="postgresql://postgres:WyzVGFTAvzETjfkWwpSQxlVTSUTOvHEE@postgres.railway.internal:5432/railway"

# ——— Email Configuration (Contact Form) ———
# SMTP ayarları - Gmail, Yandex, veya kendi mail sunucunuz
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@bantas.com
ADMIN_EMAIL=admin@bantas.com
